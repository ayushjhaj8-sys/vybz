<script>
// ======== THREE.JS GALAXY ========
const canvas = document.getElementById('bg-canvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.setSize(window.innerWidth, window.innerHeight);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.z = 3;

// Stars
const starGeo = new THREE.BufferGeometry();
const starCount = 8000;
const positions = new Float32Array(starCount*3);
const colors = new Float32Array(starCount*3);
for(let i=0;i<starCount;i++){
  positions[i*3] = (Math.random()-0.5)*20;
  positions[i*3+1] = (Math.random()-0.5)*20;
  positions[i*3+2] = (Math.random()-0.5)*20;
  const r = Math.random();
  if(r<0.33){colors[i*3]=0.85;colors[i*3+1]=0.69;colors[i*3+2]=0.22;}
  else if(r<0.66){colors[i*3]=1;colors[i*3+1]=0.42;colors[i*3+2]=0.61;}
  else{colors[i*3]=1;colors[i*3+1]=1;colors[i*3+2]=1;}
}
starGeo.setAttribute('position',new THREE.BufferAttribute(positions,3));
starGeo.setAttribute('color',new THREE.BufferAttribute(colors,3));
const starMat = new THREE.PointsMaterial({size:0.025,vertexColors:true,transparent:true,opacity:0.9});
const stars = new THREE.Points(starGeo,starMat);
scene.add(stars);

// Nebula rings
for(let r=0;r<3;r++){
  const rGeo = new THREE.RingGeometry(1.5+r*0.8,1.52+r*0.8,128);
  const rMat = new THREE.MeshBasicMaterial({color:new THREE.Color(r===0?0xd4af37:r===1?0xff6b9d:0x00d4aa),transparent:true,opacity:0.06,side:THREE.DoubleSide});
  const ring = new THREE.Mesh(rGeo,rMat);
  ring.rotation.x = Math.PI/3 + r*0.2;
  ring.rotation.y = r*0.5;
  scene.add(ring);
}

let mouseX=0, mouseY=0;
document.addEventListener('mousemove',e=>{mouseX=(e.clientX/window.innerWidth-0.5)*0.5;mouseY=(e.clientY/window.innerHeight-0.5)*0.5;});
window.addEventListener('resize',()=>{camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix();renderer.setSize(window.innerWidth,window.innerHeight);});

function animate(){
  requestAnimationFrame(animate);
  stars.rotation.y += 0.0003;
  stars.rotation.x += 0.0001;
  camera.position.x += (mouseX-camera.position.x)*0.02;
  camera.position.y += (-mouseY-camera.position.y)*0.02;
  camera.lookAt(scene.position);
  renderer.render(scene,camera);
}
animate();

// ======== CURSOR ========
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let cx=0,cy=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{cx=e.clientX;cy=e.clientY;cursor.style.left=cx+'px';cursor.style.top=cy+'px';});
setInterval(()=>{rx+=(cx-rx)*0.15;ry+=(cy-ry)*0.15;ring.style.left=rx+'px';ring.style.top=ry+'px';},16);

// ======== PAGE ROUTING ========
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
}

// ======== MODALS ========
function closeModal(name){document.getElementById('overlay-'+name).classList.remove('active');}

// ======== SIGNUP STEPS ========
let currentStep=1;

function openModal(name){
  document.getElementById('overlay-'+name).classList.add('active');
  // Reset signup form when reopened
  if(name==='signup'){
    currentStep=1;
    for(let i=1;i<=5;i++){
      const s=document.getElementById('signup-step'+i);
      const d=document.getElementById('step'+i+'-dot');
      if(s) s.style.display= i===1?'block':'none';
      if(d){ d.classList.remove('done','active'); if(i===1) d.classList.add('active'); }
    }
  }
}

function nextStep(step){
  if(step===1){
    const f=document.getElementById('s-fname').value.trim();
    const e=document.getElementById('s-email').value.trim();
    const ph=document.getElementById('s-phone').value.trim();
    const pw=document.getElementById('s-pass').value;
    if(!f||!e||!ph||!pw){showToast('⚠️','Please fill all fields bestie!','error');return;}
    if(!e.includes('@')){showToast('⚠️','Enter a valid email fr','error');return;}
    if(pw.length<8){showToast('⚠️','Password needs 8+ chars no cap','error');return;}
  }
  if(step===2){
    const dob=document.getElementById('s-dob').value;
    const gender=document.getElementById('s-gender').value;
    if(!dob||!gender){showToast('⚠️','Fill your birth details!','error');return;}
  }
  document.getElementById('signup-step'+step).style.display='none';
  document.getElementById('step'+step+'-dot').classList.add('done');
  currentStep=step+1;
  document.getElementById('signup-step'+currentStep).style.display='block';
  document.getElementById('step'+currentStep+'-dot').classList.add('active');
}
function prevStep(step){
  document.getElementById('signup-step'+step).style.display='none';
  currentStep=step-1;
  document.getElementById('signup-step'+currentStep).style.display='block';
}

function toggleHobby(el){el.classList.toggle('selected');}

function previewPhotos(input){
  const preview=document.getElementById('photo-preview');
  preview.innerHTML='';
  window._pendingPhotos = [...input.files];
  [...input.files].forEach(file=>{
    const r=new FileReader();
    r.onload=e=>{
      const img=document.createElement('img');
      img.className='preview-img';
      img.src=e.target.result;
      preview.appendChild(img);
    };
    r.readAsDataURL(file);
  });
  showToast('📸',input.files.length+' photo(s) selected! Will upload after signup.','success');
}

function formatAadhaar(input){
  let v=input.value.replace(/\D/g,'').substring(0,12);
  let f='';
  for(let i=0;i<v.length;i++){if(i>0&&i%4===0)f+=' ';f+=v[i];}
  input.value=f;
}

function takeSelfie(){showToast('📷','Camera access requested. Live selfie captured!','success');}

async function completeSignup(){
  const aadhaar=document.getElementById('s-aadhaar').value.replace(/\s/g,'');
  const insta=document.getElementById('s-insta').value.trim();
  if(!aadhaar||aadhaar.length<12){showToast('⚠️','Enter your valid 12-digit Aadhaar fr','error');return;}
  if(!insta){showToast('⚠️','Drop your Insta handle bestie!','error');return;}

  const fname = document.getElementById('s-fname').value.trim();
  const lname = document.getElementById('s-lname').value.trim();
  const email = document.getElementById('s-email').value.trim();
  const phone = document.getElementById('s-phone').value.trim();
  const password = document.getElementById('s-pass').value;
  const dob = document.getElementById('s-dob').value;
  const btime = document.getElementById('s-btime').value;
  const bcity = document.getElementById('s-bcity').value;
  const gender = document.getElementById('s-gender').value;
  const looking = document.getElementById('s-looking').value;
  const bio = document.getElementById('s-bio').value;
  const prof = document.getElementById('s-prof').value;

  const diet = document.getElementById('s-diet').value;
  const sleep = document.getElementById('s-sleep').value;
  const exercise = document.getElementById('s-exercise').value;
  const hobbies = [...document.querySelectorAll('.hobby-tag.selected')].map(h=>h.textContent.trim());
  const extra = { dob, birthTime:btime, birthCity:bcity, gender, lookingFor:looking, bio, profession:prof, hobbies, diet, sleep, exercise, aadhaar, instagram:insta };

  if(window.firebaseSignup){
    showToast('⏳','Creating your account...','success');
    const result = await window.firebaseSignup(fname, lname, email, phone, password, extra);
    if(result.success){
      closeModal('signup');
      showToast('🎉',"Yassss "+fname+"! Welcome to Vybz 💜",'success');
      // Upload pending photos
      if(window._pendingPhotos && window._pendingPhotos.length > 0 && window.uploadProfilePhoto) {
        for(const photo of window._pendingPhotos) {
          await window.uploadProfilePhoto(photo);
        }
        window._pendingPhotos = [];
      }
      setTimeout(()=>showPage('dashboard'), 1200);
    }
  } else {
    // Fallback if Firebase not configured yet
    closeModal('signup');
    showToast('🎉','Account created! Welcome to Vybz 💜','success');
    setTimeout(()=>showPage('dashboard'),1200);
  }
}

