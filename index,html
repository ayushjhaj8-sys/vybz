  }
}

// ======== COUNTER ANIMATION ========
function animateCounter(el, target, suffix=''){
  let count=0;
  const step=Math.ceil(target/80);
  const t=setInterval(()=>{
    count=Math.min(count+step,target);
    el.textContent=(count>=1000?(count/1000).toFixed(1)+'K':count)+suffix;
    if(count>=target) clearInterval(t);
  },20);
}

