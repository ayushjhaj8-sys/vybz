<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vybz ✨ — Find Your Vibe</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

<!-- ✅ FIREBASE SDK -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
import { getFirestore, doc, setDoc, getDoc, addDoc, collection, getDocs, updateDoc, onSnapshot, query, orderBy, where, limit, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import { getDatabase, ref, set, onValue, onDisconnect, serverTimestamp as rtServerTimestamp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";
import { getStorage, ref as storageRef, uploadBytes, getDownloadURL } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-storage.js";

const firebaseConfig = {
  apiKey: "AIzaSyAQZF2fJxYkV7o-7joLsP5iRz0Nj5SAADA",
  authDomain: "vybz-8cbfe.firebaseapp.com",
  projectId: "vybz-8cbfe",
  storageBucket: "vybz-8cbfe.firebasestorage.app",
  messagingSenderId: "864955473939",
  appId: "1:864955473939:web:013cf07cfb6c7b77361fe6",
  databaseURL: "https://vybz-8cbfe-default-rtdb.firebaseio.com"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const rtdb = getDatabase(app);
const storage = getStorage(app);
window._auth = auth; window._db = db; window._rtdb = rtdb; window._storage = storage;

// ===== ONLINE PRESENCE =====
function setUserOnline(uid) {
  const statusRef = ref(rtdb, "status/" + uid);
  onDisconnect(statusRef).set({ state: "offline", lastSeen: rtServerTimestamp() });
  set(statusRef, { state: "online", lastSeen: rtServerTimestamp() });
}
window.watchUserOnlineStatus = function(uid, cb) {
  onValue(ref(rtdb, "status/" + uid), snap => {
    const d = snap.val(); cb(d ? d.state === "online" : false);
  });
};

// ===== AUTH STATE =====
onAuthStateChanged(auth, async (user) => {
  if (user) {
    const snap = await getDoc(doc(db, "users", user.uid));
    if (snap.exists()) {
      window._currentUser = { uid: user.uid, ...snap.data() };
      const n = document.querySelector(".user-name");
      if(n) n.textContent = snap.data().firstName + " " + (snap.data().lastName||"");
      const h = document.querySelector("#page-dashboard .dash-header h1");
      if(h) h.innerHTML = `Welcome back, <span style="color:var(--gold)">${snap.data().firstName} ✨</span>`;
      setUserOnline(user.uid);
      loadRealMatches(user.uid);
      loadConversations(user.uid);
      watchUnreadMessages(user.uid);
    }
  } else { window._currentUser = null; }
});

// ===== SIGNUP =====
window.firebaseSignup = async function(fname,lname,email,phone,password,extra) {
  try {
    const {user} = await createUserWithEmailAndPassword(auth,email,password);
    await setDoc(doc(db,"users",user.uid),{firstName:fname,lastName:lname,email,phone,...extra,isVerified:false,isAdmin:false,createdAt:serverTimestamp(),uid:user.uid,matches:[],likedBy:[]});
    return {success:true};
  } catch(e) {
    const m = e.code==="auth/email-already-in-use"?"That email is taken 👀":e.code==="auth/weak-password"?"Password too weak 💪":"Signup failed: "+e.message;
    showToast("🚫",m,"error"); return {success:false};
  }
};

// ===== LOGIN =====
window.firebaseLogin = async function(email,password) {
  try { await signInWithEmailAndPassword(auth,email,password); return {success:true}; }
  catch(e) {
    const m = e.code==="auth/invalid-credential"?"Wrong email or password fr":e.code==="auth/too-many-requests"?"Too many attempts! Chill 😅":"Login failed";
    showToast("🚫",m,"error"); return {success:false};
  }
};

// ===== LOGOUT =====
window.firebaseLogout = async function() {
  if(window._currentUser) await set(ref(rtdb,"status/"+window._currentUser.uid),{state:"offline",lastSeen:rtServerTimestamp()});
  await signOut(auth); window._currentUser = null;
};

// ===== REAL PHOTO UPLOAD =====
window.uploadProfilePhoto = async function(file) {
  if(!window._currentUser) return null;
  try {
    showToast("⏳","Uploading photo...","success");
    const fileRef = storageRef(storage, "profiles/" + window._currentUser.uid + "/" + Date.now() + "_" + file.name);
    await uploadBytes(fileRef, file);
    const url = await getDownloadURL(fileRef);
    // Save URL to user profile
    await updateDoc(doc(db,"users",window._currentUser.uid), { photoURL: url, photos: [...(window._currentUser.photos||[]), url] });
    window._currentUser.photoURL = url;
    showToast("✅","Photo uploaded!","success");
    return url;
  } catch(e) {
    showToast("⚠️","Photo upload failed: "+e.message,"error");
    return null;
  }
};

// ===== LOAD REAL MATCHES =====
async function loadRealMatches(uid) {
  try {
    const myData = window._currentUser;
    const lookingFor = myData?.lookingFor || "Any";
    const myGender = myData?.gender || "";
    // Load users - filter by gender preference
    const snap = await getDocs(query(collection(db,"users"), limit(50)));
    const users = [];
    snap.forEach(d => {
      const u = d.data();
      if(d.id === uid) return; // skip self
      if(u.isBanned) return; // skip banned
      // Gender filter
      if(lookingFor !== "Any" && u.gender !== lookingFor) return;
      // Don't show users who already liked/matched
      users.push({id:d.id,...u});
    });
    window._realMatches = users;
    renderRealMatchCards(users);
  } catch(e) { console.log("Match load error:",e); }
}

function renderRealMatchCards(users) {
  const grid = document.getElementById("matches-grid");
  if(!grid) return;
  if(users.length===0){
    grid.innerHTML=`<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--muted)"><div style="font-size:3rem;margin-bottom:16px">👀</div><div>No matches yet! Come back soon 💜</div></div>`;
    return;
  }
  const emojis=["🌙","🌊","🌸","🌿","⭐","🌺","💫","🌻","🦋","🔮"];
  const bgs=["match-img-bg1","match-img-bg2","match-img-bg3","match-img-bg4"];
  grid.innerHTML = users.map((u,i)=>{
    // Astro compat based on birth dates
    let compat = 75;
    if(u.dob && window._currentUser?.dob) {
      const myMonth = new Date(window._currentUser.dob).getMonth();
      const theirMonth = new Date(u.dob).getMonth();
      const diff = Math.abs(myMonth - theirMonth);
      compat = diff===0?99:diff<=2?92:diff<=4?87:diff<=6?82:75;
    } else {
      compat = 75+((u.firstName.charCodeAt(0)+uid.length)%20);
    }
    const hobbies = (u.hobbies||["Music","Travel","Yoga"]).slice(0,3);
    return `<div class="match-card" onclick="openRealProfile('${u.id}')">
      <div class="match-img ${bgs[i%4]}">
        ${u.photoURL ? `<img src="${u.photoURL}" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;border-radius:0" onerror="this.style.display='none'">` : ''}<span style="font-size:5rem;position:relative;z-index:1">${emojis[i%10]}</span>
        <div class="match-compat">${compat}% ✨</div>
        <div id="dot-${u.id}" style="position:absolute;bottom:12px;left:12px;width:10px;height:10px;border-radius:50%;background:#94a3b8;border:2px solid var(--deep)"></div>
      </div>
      <div class="match-info">
        <div class="match-name">${u.firstName} ${u.lastName||""}</div>
        <div class="match-meta">${u.profession||"User"} · ${u.birthCity||"India"}</div>
        <div class="match-tags">${hobbies.map(h=>`<span class="match-tag">${h}</span>`).join("")}</div>
      </div>
      <div class="match-actions">
        <button class="match-btn match-btn-pass" onclick="event.stopPropagation();passMatch(this,'${u.firstName}')">✕ Pass</button>
        <button class="match-btn match-btn-like" onclick="event.stopPropagation();likeRealUser('${u.id}','${u.firstName}')">💫 Like</button>
      </div>
    </div>`;
  }).join("");
  users.forEach(u => window.watchUserOnlineStatus(u.id, online => {
    const dot = document.getElementById("dot-"+u.id);
    if(dot) dot.style.background = online ? "#2ed573" : "#94a3b8";
  }));
}
window.renderRealMatchCards = renderRealMatchCards;

// ===== LIKE SYSTEM =====
window.likeRealUser = async function(targetUid, targetName) {
  if(!window._currentUser){showToast("⚠️","Login first!","error");return;}
  const myUid = window._currentUser.uid;
  try {
    await setDoc(doc(db,"likes",myUid+"_"+targetUid),{from:myUid,to:targetUid,timestamp:serverTimestamp()});
    const rev = await getDoc(doc(db,"likes",targetUid+"_"+myUid));
    if(rev.exists()) {
      const matchId = [myUid,targetUid].sort().join("_");
      await setDoc(doc(db,"matches",matchId),{users:[myUid,targetUid],createdAt:serverTimestamp()});
      showToast("🎉","IT'S A MATCH with "+targetName+"!! 💜","success");
      await addDoc(collection(db,"notifications"),{to:targetUid,from:myUid,type:"match",message:"You matched with "+window._currentUser.firstName+"! 💜",read:false,timestamp:serverTimestamp()});
    } else {
      showToast("💫","You liked "+targetName+"! Waiting... 🤞","success");
    }
  } catch(e){showToast("⚠️","Could not like right now","error");}
};

// ===== CONVERSATIONS =====
function loadConversations(uid) {
  const q = query(collection(db,"matches"),where("users","array-contains",uid));
  onSnapshot(q, async snap => {
    const convList = document.getElementById("conversations-list");
    if(!convList) return;
    if(snap.empty){
      convList.innerHTML=`<div style="text-align:center;padding:40px;color:var(--muted)"><div style="font-size:2.5rem;margin-bottom:12px">💬</div><div>No chats yet! Like someone first 💜</div></div>`;
      return;
    }
    const convs=[];
    for(const d of snap.docs){
      const data=d.data();
      const otherUid=data.users.find(u=>u!==uid);
      const otherSnap=await getDoc(doc(db,"users",otherUid));
      if(otherSnap.exists()) convs.push({matchId:d.id,otherUid,other:otherSnap.data()});
    }
    const emojis=["🌙","🌊","🌸","🌿","⭐","🌺"];
    convList.innerHTML=convs.map((c,i)=>`
      <div class="user-row" style="cursor:pointer;border:1px solid var(--border);border-radius:12px;margin-bottom:8px" onclick="openChat('${c.matchId}','${c.otherUid}','${c.other.firstName}')">
        <div class="user-row-avatar uav${(i%5)+1}" style="font-size:1.5rem">${emojis[i%6]}</div>
        <div class="user-row-info">
          <div class="user-row-name">${c.other.firstName} ${c.other.lastName||""}</div>
          <div class="user-row-meta">Tap to chat 💬</div>
        </div>
        <div id="conv-dot-${c.otherUid}" style="width:10px;height:10px;border-radius:50%;background:#94a3b8;flex-shrink:0"></div>
      </div>`).join("");
    convs.forEach(c=>window.watchUserOnlineStatus(c.otherUid,online=>{
      const dot=document.getElementById("conv-dot-"+c.otherUid);
      if(dot) dot.style.background=online?"#2ed573":"#94a3b8";
    }));
  });
}

// ===== OPEN CHAT =====
let _unsubChat=null;
window.openChat = function(matchId,otherUid,otherName) {
  window._currentChatId=matchId; window._currentChatOtherUid=otherUid;
  const chatName=document.querySelector(".chat-name");
  if(chatName) chatName.textContent=otherName;
  window.watchUserOnlineStatus(otherUid,online=>{
    const st=document.querySelector(".chat-status");
    if(st){st.textContent=online?"● Online now":"● Offline";st.style.color=online?"var(--teal)":"var(--muted)";}
  });
  checkContactLock(matchId);
  if(_unsubChat) _unsubChat();
  const q=query(collection(db,"chats",matchId,"messages"),orderBy("timestamp","asc"),limit(50));
  _unsubChat=onSnapshot(q,snap=>{
    const msgs=document.getElementById("chat-messages");
    if(!msgs) return;
    msgs.innerHTML="";
    snap.forEach(d=>{
      const data=d.data(); const isMe=data.from===window._currentUser?.uid;
      const div=document.createElement("div"); div.className="msg "+(isMe?"msg-me":"msg-them");
      const time=data.timestamp?new Date(data.timestamp.toDate()).toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit"}):"Just now";
      div.innerHTML=`<div class="msg-bubble">${data.text}</div><div class="msg-time">${time}</div>`;
      msgs.appendChild(div);
    });
    msgs.scrollTop=msgs.scrollHeight;
  });
  switchTabDirect("chat");
  document.getElementById("chat-panel").style.display="flex";
};

// ===== SEND REAL MESSAGE =====
window.sendMessage = async function() {
  const input=document.getElementById("chat-input");
  const msg=input.value.trim();
  if(!msg) return;
  if(!window._currentUser){showToast("⚠️","Login first!","error");return;}
  if(!window._currentChatId){showToast("⚠️","Select a match to chat with!","error");return;}
  input.value="";
  try {
    await addDoc(collection(db,"chats",window._currentChatId,"messages"),{from:window._currentUser.uid,to:window._currentChatOtherUid,text:msg,timestamp:serverTimestamp(),read:false});
    await addDoc(collection(db,"notifications"),{to:window._currentChatOtherUid,from:window._currentUser.uid,type:"message",message:window._currentUser.firstName+": "+msg.substring(0,50),read:false,timestamp:serverTimestamp()});
  } catch(e){showToast("⚠️","Message failed to send","error");}
};

// ===== 30 DAY LOCK =====
async function checkContactLock(matchId) {
  try {
    const snap=await getDoc(doc(db,"matches",matchId));
    if(!snap.exists()) return;
    const createdAt=snap.data().createdAt?.toDate()||new Date();
    const unlockDate=new Date(createdAt.getTime()+30*24*60*60*1000);
    const diff=unlockDate-new Date();
    const lockBox=document.querySelector(".countdown-box");
    const instaDiv=document.querySelector(".insta-reveal");
    if(diff<=0){
      if(lockBox) lockBox.style.display="none";
      if(instaDiv){
        instaDiv.style.display="block";
        const otherSnap=await getDoc(doc(db,"users",window._currentChatOtherUid));
        if(otherSnap.exists()) instaDiv.querySelector("p").textContent="🎉 30 days done! Instagram: "+(otherSnap.data().instagram||"Not shared");
      }
    } else {
      const d=Math.floor(diff/(1000*60*60*24)),h=Math.floor((diff%(1000*60*60*24))/(1000*60*60)),m=Math.floor((diff%(1000*60*60))/(1000*60));
      const display=document.getElementById("countdown-display");
      if(display) display.textContent=d+"d "+h+"h "+m+"m";
      if(lockBox) lockBox.style.display="block";
      if(instaDiv) instaDiv.style.display="none";
    }
  } catch(e){}
}

// ===== NOTIFICATIONS =====
function watchUnreadMessages(uid) {
  const q=query(collection(db,"notifications"),where("to","==",uid),where("read","==",false));
  onSnapshot(q,snap=>{
    const badge=document.getElementById("notif-badge");
    if(badge){badge.textContent=snap.size>0?snap.size:"";badge.style.display=snap.size>0?"flex":"none";}
    snap.docChanges().forEach(change=>{
      if(change.type==="added"){
        const data=change.doc.data();
        if(data.type==="match") showToast("🎉",data.message,"success");
        if(data.type==="message") showToast("💬",data.message,"success");
      }
    });
  });
}

// ===== OPEN REAL PROFILE =====
window.openRealProfile = function(uid) {
  const user=window._realMatches?.find(u=>u.id===uid);
  if(!user) return;
  const compat=75+Math.floor(Math.random()*20);
  const hobbies=user.hobbies||["Music","Travel","Yoga"];
  document.getElementById("profile-hero-content").innerHTML=`
    <div class="profile-photo" style="overflow:hidden">
      ${user.photoURL ? `<img src="${user.photoURL}" style="width:100%;height:100%;object-fit:cover;border-radius:24px" onerror="this.style.display='none'">` : '🌟'}
      <div class="profile-verified-banner">${user.isVerified?"✓ Verified":"⏳ Pending"}</div></div>
    <div>
      <h2>${user.firstName} ${user.lastName||""}</h2>
      <div class="profile-sub">${user.profession||"User"} · ${user.birthCity||"India"}</div>
      <div class="profile-tags">${hobbies.map(h=>`<span class="profile-tag">${h}</span>`).join("")}<span class="profile-tag" style="border-color:var(--rose);color:var(--rose)">${compat}% Match</span></div>
      <p class="profile-bio">${user.bio||"No bio yet 😏"}</p>
      <div class="profile-action-btns">
        <button class="btn btn-primary" onclick="likeRealUser('${uid}','${user.firstName}');closeProfile()">💫 Like</button>
        <button class="btn btn-outline" onclick="closeProfile()">✕ Close</button>
      </div>
    </div>`;
  document.getElementById("profile-astro-section").innerHTML=`
    <div class="astro-card">
      <div class="astro-title">🌟 Their Vibe</div>
      <div class="astro-grid">
        <div class="astro-item"><div class="astro-item-label">Diet</div><div class="astro-item-val">${user.diet||"Not set"}</div></div>
        <div class="astro-item"><div class="astro-item-label">Sleep</div><div class="astro-item-val">${user.sleep||"Not set"}</div></div>
        <div class="astro-item"><div class="astro-item-label">Exercise</div><div class="astro-item-val">${user.exercise||"Not set"}</div></div>
        <div class="astro-item"><div class="astro-item-label">City</div><div class="astro-item-val">${user.birthCity||"Not set"}</div></div>
      </div>
    </div>`;
  document.getElementById("profile-overlay").classList.add("active");
};

// ===== ADMIN =====
window.loadAdminUsers = async function() {
  try {
    const snap=await getDocs(query(collection(db,"users"),orderBy("createdAt","desc"),limit(20)));
    const users=[]; snap.forEach(d=>users.push({id:d.id,...d.data()}));
    // Render real users in admin panel
    const list=document.getElementById("admin-users-list");
    if(list && users.length>0){
      list.innerHTML=users.map((u,i)=>`
        <div class="user-row">
          <div class="user-row-avatar uav${(i%5)+1}" style="font-size:1.2rem">
            ${u.photoURL?`<img src="${u.photoURL}" style="width:40px;height:40px;border-radius:50%;object-fit:cover">`:"👤"}
          </div>
          <div class="user-row-info">
            <div class="user-row-name"><span class="status-dot dot-${u.isBanned?"flagged":u.isVerified?"verified":"pending"}"></span>${u.firstName||"?"} ${u.lastName||""}</div>
            <div class="user-row-meta">${u.email||""} · ${u.isVerified?"Verified":"Pending"}</div>
          </div>
          <div class="user-row-actions">
            <button class="action-btn action-verify" onclick="window.verifyUser('${u.id}','${u.firstName}')">✓</button>
            <button class="action-btn action-view" onclick="showToast('👁️','${u.firstName}: ${u.email||""}','success')">👁</button>
            <button class="action-btn action-ban" onclick="window.banUser('${u.id}','${u.firstName}')">✕</button>
          </div>
        </div>`).join("");
      // Update total users count
      const numEl=document.getElementById("admin-users");
      if(numEl) numEl.textContent=users.length.toLocaleString("en-IN");
    }
    return users;
  } catch(e){console.log("Admin load error:",e);return [];}
};
window.banUser=async function(uid,name){try{await updateDoc(doc(db,"users",uid),{isBanned:true});showToast("🚫",name+" banned","success");}catch(e){showToast("⚠️","Could not ban","error");}};
window.verifyUser=async function(uid,name){try{await updateDoc(doc(db,"users",uid),{isVerified:true});showToast("✅",name+" verified!","success");}catch(e){showToast("⚠️","Could not verify","error");}};

console.log("🔥 Vybz Real-Time Chat Ready!");
</script>
<style>
:root {
  --deep: #080010;
  --midnight: #0f0020;
  --violet: #2e1065;
  --gold: #a855f7;
  --gold2: #d946ef;
  --rose: #f43f5e;
  --teal: #06b6d4;
  --cream: #f0e6ff;
  --muted: #94a3b8;
  --card: rgba(255,255,255,0.05);
  --border: rgba(168,85,247,0.25);
  --red: #ff4757;
  --green: #2ed573;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--deep);
  color: var(--cream);
  overflow-x: hidden;
  cursor: none;
}
/* Custom Cursor */
.cursor { position:fixed; width:12px; height:12px; background:var(--gold); border-radius:50%; pointer-events:none; z-index:99999; transform:translate(-50%,-50%); transition:transform 0.1s; mix-blend-mode:difference; }
.cursor-ring { position:fixed; width:36px; height:36px; border:1.5px solid var(--gold); border-radius:50%; pointer-events:none; z-index:99998; transform:translate(-50%,-50%); transition:all 0.15s ease; }

/* Canvas */
#bg-canvas { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; }

/* App Wrapper */
#app { position:relative; z-index:10; }

/* ===================== NAV ===================== */
nav {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 60px;
  background:rgba(8,0,16,0.85);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.logo {
  font-family:'Syne',sans-serif;
  font-size:1.5rem;
  color:var(--gold);
  letter-spacing:2px;
  text-shadow:0 0 20px rgba(168,85,247,0.5);
}
.logo span { color:var(--rose); }
.nav-links { display:flex; gap:32px; }
.nav-links a {
  color:var(--muted); text-decoration:none;
  font-size:0.85rem; letter-spacing:1px; text-transform:uppercase;
  transition:color 0.3s;
}
.nav-links a:hover { color:var(--gold); }
.nav-btns { display:flex; gap:12px; }
.btn { padding:10px 24px; border-radius:50px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; cursor:pointer; transition:all 0.3s; letter-spacing:1px; border:none; }
.btn-outline { background:transparent; border:1px solid var(--gold); color:var(--gold); }
.btn-outline:hover { background:var(--gold); color:var(--deep); }
.btn-primary { background:linear-gradient(135deg,var(--gold),var(--rose)); color:var(--deep); }
.btn-primary:hover { transform:scale(1.05); box-shadow:0 0 25px rgba(168,85,247,0.4); }

/* ===================== PAGES ===================== */
.page { display:none; min-height:100vh; padding-top:80px; }
.page.active { display:block; }

/* ===================== HERO ===================== */
#page-home {
  display:none; flex-direction:column; align-items:center; justify-content:center;
  min-height:100vh; text-align:center; padding:0 20px;
}
#page-home.active { display:flex; }

.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(168,85,247,0.1); border:1px solid var(--border);
  padding:8px 20px; border-radius:50px; margin-bottom:32px;
  font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:var(--gold);
  animation: fadeDown 1s ease both;
}
.hero-badge::before { content:'✦'; }

.hero-title {
  font-family:'Syne',sans-serif;
  font-size:clamp(2.5rem,7vw,5.5rem);
  line-height:1.1;
  margin-bottom:24px;
  animation: fadeUp 1s ease 0.2s both;
}
.hero-title .line1 { display:block; color:var(--cream); }
.hero-title .line2 { display:block; background:linear-gradient(135deg,var(--gold),var(--rose),var(--teal)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }

.hero-sub {
  font-size:1.1rem; color:var(--muted); max-width:560px; line-height:1.8;
  margin-bottom:48px; font-weight:300;
  animation: fadeUp 1s ease 0.4s both;
}

.hero-btns { display:flex; gap:16px; flex-wrap:wrap; justify-content:center; animation: fadeUp 1s ease 0.6s both; }
.btn-lg { padding:16px 40px; font-size:1rem; }

.hero-stats {
  display:flex; gap:60px; margin-top:80px;
  animation: fadeUp 1s ease 0.8s both;
}
.stat { text-align:center; }
.stat-num { font-family:'Syne',sans-serif; font-size:2rem; color:var(--gold); font-weight:700; }
.stat-label { font-size:0.75rem; color:var(--muted); letter-spacing:2px; text-transform:uppercase; margin-top:4px; }

/* Floating orbs */
.orb { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; animation:orbFloat 8s ease-in-out infinite; }
.orb1 { width:400px; height:400px; background:rgba(168,85,247,0.08); top:10%; left:-10%; }
.orb2 { width:300px; height:300px; background:rgba(255,107,157,0.08); top:40%; right:-5%; animation-delay:-3s; }
.orb3 { width:250px; height:250px; background:rgba(0,212,170,0.06); bottom:10%; left:20%; animation-delay:-6s; }

@keyframes orbFloat { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-30px) scale(1.05)} }
@keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
@keyframes fadeDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }

/* Zodiac ring */
.zodiac-ring {
  position:absolute; width:600px; height:600px;
  border:1px solid rgba(168,85,247,0.1);
  border-radius:50%; top:50%; left:50%; transform:translate(-50%,-50%);
  animation:spin 60s linear infinite;
  pointer-events:none;
}
.zodiac-ring::before {
  content:'♈ ♉ ♊ ♋ ♌ ♍ ♎ ♏ ♐ ♑ ♒ ♓';
  position:absolute; width:100%; top:-14px; left:0;
  text-align:center; letter-spacing:45px; font-size:14px; color:rgba(168,85,247,0.3);
}
@keyframes spin { from{transform:translate(-50%,-50%) rotate(0)} to{transform:translate(-50%,-50%) rotate(360deg)} }

/* ===================== MODAL / OVERLAY ===================== */
.overlay {
  position:fixed; inset:0; z-index:2000;
  background:rgba(8,0,16,0.97); backdrop-filter:blur(20px);
  display:none; align-items:center; justify-content:center;
  padding:20px;
}
.overlay.active { display:flex; }

.modal {
  background:linear-gradient(135deg,rgba(26,10,61,0.9),rgba(13,8,37,0.9));
  border:1px solid var(--border);
  border-radius:24px; padding:48px;
  width:100%; max-width:520px;
  max-height:90vh; overflow-y:auto;
  position:relative;
  box-shadow:0 0 60px rgba(168,85,247,0.1);
  animation:modalIn 0.4s ease;
}
@keyframes modalIn { from{opacity:0;transform:scale(0.95)} to{opacity:1;transform:scale(1)} }

.modal-close {
  position:absolute; top:20px; right:20px;
  background:none; border:none; color:var(--muted);
  font-size:1.4rem; cursor:pointer; transition:color 0.2s;
}
.modal-close:hover { color:var(--rose); }

.modal-title {
  font-family:'Syne',sans-serif; font-size:1.6rem;
  color:var(--gold); margin-bottom:8px; text-align:center;
}
.modal-sub { color:var(--muted); font-size:0.85rem; text-align:center; margin-bottom:32px; }

/* Form */
.form-group { margin-bottom:20px; }
.form-label { display:block; font-size:0.8rem; letter-spacing:1px; text-transform:uppercase; color:var(--muted); margin-bottom:8px; }
.form-input, .form-select, .form-textarea {
  width:100%; padding:14px 18px;
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(168,85,247,0.2);
  border-radius:12px; color:var(--cream);
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem;
  transition:border-color 0.3s, box-shadow 0.3s;
  outline:none;
}
.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color:var(--gold);
  box-shadow:0 0 20px rgba(168,85,247,0.15);
}
.form-select option { background:var(--midnight); }
.form-textarea { resize:vertical; min-height:80px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

.form-steps { display:flex; gap:8px; margin-bottom:32px; }
.step-dot {
  flex:1; height:4px; border-radius:4px;
  background:rgba(168,85,247,0.2); transition:background 0.3s;
}
.step-dot.active { background:var(--gold); }
.step-dot.done { background:var(--teal); }

.step-title { font-size:0.75rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:20px; }

/* Hobby tags */
.hobby-grid { display:flex; flex-wrap:wrap; gap:8px; }
.hobby-tag {
  padding:8px 16px; border-radius:50px;
  border:1px solid rgba(168,85,247,0.25);
  background:transparent; color:var(--muted);
  font-size:0.8rem; cursor:pointer; transition:all 0.2s;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.hobby-tag.selected { border-color:var(--gold); background:rgba(168,85,247,0.15); color:var(--gold); }

/* Photo upload */
.photo-upload {
  border:2px dashed rgba(168,85,247,0.3);
  border-radius:16px; padding:40px;
  text-align:center; cursor:pointer; transition:all 0.3s;
}
.photo-upload:hover { border-color:var(--gold); background:rgba(168,85,247,0.05); }
.photo-upload-icon { font-size:2.5rem; margin-bottom:12px; }
.photo-preview { display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; }
.preview-img {
  width:80px; height:80px; border-radius:12px;
  object-fit:cover; border:2px solid var(--gold);
}

/* Verification */
.verify-box {
  background:rgba(0,212,170,0.08); border:1px solid rgba(0,212,170,0.3);
  border-radius:12px; padding:20px; margin-bottom:20px;
  display:flex; align-items:center; gap:16px;
}
.verify-icon { font-size:2rem; }
.verify-status { font-size:0.8rem; color:var(--teal); }

/* ===================== DASHBOARD ===================== */
#page-dashboard {
  min-height:100vh; padding:100px 40px 40px;
}
.dash-header { margin-bottom:40px; }
.dash-header h1 { font-family:'Syne',sans-serif; font-size:2rem; color:var(--gold); }
.dash-header p { color:var(--muted); margin-top:8px; }

.dash-grid { display:grid; grid-template-columns:280px 1fr 320px; gap:24px; }

/* Sidebar */
.sidebar {
  background:var(--card); border:1px solid var(--border);
  border-radius:20px; padding:24px; height:fit-content;
}
.user-card { text-align:center; margin-bottom:32px; }
.user-avatar {
  width:80px; height:80px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--rose));
  margin:0 auto 12px; display:flex; align-items:center; justify-content:center;
  font-size:2rem; font-weight:700; color:var(--deep);
  border:3px solid var(--gold);
  position:relative;
}
.verify-badge {
  position:absolute; bottom:-4px; right:-4px;
  width:24px; height:24px; background:var(--teal);
  border-radius:50%; border:2px solid var(--deep);
  display:flex; align-items:center; justify-content:center;
  font-size:0.7rem;
}
.user-name { font-family:'Syne',sans-serif; font-size:1.1rem; color:var(--gold); }
.user-sign { font-size:0.8rem; color:var(--muted); margin-top:4px; }
.compatibility-score {
  background:linear-gradient(135deg,rgba(168,85,247,0.1),rgba(255,107,157,0.1));
  border:1px solid var(--border); border-radius:12px; padding:16px;
  text-align:center; margin-bottom:16px;
}
.score-num { font-family:'Syne',sans-serif; font-size:2rem; color:var(--gold); }
.score-label { font-size:0.7rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; }

.sidebar-nav { display:flex; flex-direction:column; gap:8px; }
.sidebar-link {
  display:flex; align-items:center; gap:12px;
  padding:12px 16px; border-radius:12px; cursor:pointer;
  color:var(--muted); font-size:0.85rem; transition:all 0.2s;
  border:none; background:none; width:100%; text-align:left;
}
.sidebar-link:hover, .sidebar-link.active { background:rgba(168,85,247,0.1); color:var(--gold); }
.sidebar-link .icon { font-size:1.1rem; }

/* Main feed */
.feed-tabs { display:flex; gap:4px; margin-bottom:24px; background:rgba(255,255,255,0.03); border-radius:12px; padding:4px; }
.feed-tab {
  flex:1; padding:10px; text-align:center; border-radius:10px;
  font-size:0.8rem; letter-spacing:1px; text-transform:uppercase;
  cursor:pointer; transition:all 0.2s; border:none; background:none; color:var(--muted);
}
.feed-tab.active { background:rgba(168,85,247,0.15); color:var(--gold); }

.matches-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.match-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:20px; overflow:hidden; cursor:pointer;
  transition:all 0.3s; position:relative;
}
.match-card:hover { transform:translateY(-4px); box-shadow:0 20px 40px rgba(0,0,0,0.3); border-color:var(--gold); }
.match-img {
  height:180px;
  display:flex; align-items:center; justify-content:center;
  font-size:4rem; position:relative;
}
.match-img-bg1 { background:linear-gradient(135deg,#1a0a3d,#3d1a6b); }
.match-img-bg2 { background:linear-gradient(135deg,#0a2a1a,#1a6b3d); }
.match-img-bg3 { background:linear-gradient(135deg,#2a0a1a,#6b1a3d); }
.match-img-bg4 { background:linear-gradient(135deg,#0a1a2a,#1a3d6b); }
.match-compat {
  position:absolute; top:12px; right:12px;
  background:rgba(8,0,16,0.85); border:1px solid var(--gold);
  border-radius:50px; padding:4px 10px;
  font-size:0.75rem; color:var(--gold); font-weight:600;
}
.match-info { padding:16px; }
.match-name { font-family:'Syne',sans-serif; font-size:1rem; color:var(--cream); }
.match-meta { font-size:0.75rem; color:var(--muted); margin-top:4px; }
.match-tags { display:flex; gap:6px; margin-top:10px; flex-wrap:wrap; }
.match-tag {
  padding:3px 10px; border-radius:50px;
  background:rgba(168,85,247,0.1); color:var(--gold);
  font-size:0.7rem;
}
.match-actions { display:flex; gap:8px; padding:0 16px 16px; }
.match-btn {
  flex:1; padding:10px; border-radius:10px; border:none;
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; cursor:pointer; transition:all 0.2s;
}
.match-btn-pass { background:rgba(255,255,255,0.05); color:var(--muted); }
.match-btn-pass:hover { background:rgba(255,71,87,0.1); color:var(--red); }
.match-btn-like { background:linear-gradient(135deg,var(--gold),var(--rose)); color:var(--deep); font-weight:600; }
.match-btn-like:hover { transform:scale(1.03); }

/* Chat panel */
.chat-panel {
  background:var(--card); border:1px solid var(--border);
  border-radius:20px; display:flex; flex-direction:column; height:600px;
}
.chat-header {
  padding:20px 24px; border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:12px;
}
.chat-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--rose),var(--violet)); display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
.chat-name { font-family:'Syne',sans-serif; font-size:0.95rem; color:var(--cream); }
.chat-status { font-size:0.7rem; color:var(--teal); }
.chat-lock {
  margin-left:auto; background:rgba(168,85,247,0.1);
  border:1px solid var(--border); border-radius:50px;
  padding:6px 12px; font-size:0.7rem; color:var(--gold);
  display:flex; align-items:center; gap:6px;
}

.chat-messages { flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:12px; }
.chat-messages::-webkit-scrollbar { width:4px; }
.chat-messages::-webkit-scrollbar-track { background:transparent; }
.chat-messages::-webkit-scrollbar-thumb { background:rgba(168,85,247,0.2); border-radius:2px; }

.msg { max-width:75%; }
.msg-them { align-self:flex-start; }
.msg-me { align-self:flex-end; }
.msg-bubble {
  padding:12px 16px; border-radius:18px; font-size:0.85rem; line-height:1.5;
}
.msg-them .msg-bubble { background:rgba(255,255,255,0.07); color:var(--cream); border-radius:18px 18px 18px 4px; }
.msg-me .msg-bubble { background:linear-gradient(135deg,rgba(168,85,247,0.3),rgba(255,107,157,0.2)); color:var(--cream); border-radius:18px 18px 4px 18px; }
.msg-time { font-size:0.65rem; color:var(--muted); margin-top:4px; text-align:right; }

.chat-input-area {
  padding:16px 20px; border-top:1px solid var(--border);
  display:flex; gap:12px; align-items:center;
}
.chat-input {
  flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(168,85,247,0.2);
  border-radius:50px; padding:12px 20px; color:var(--cream);
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; outline:none;
}
.chat-input:focus { border-color:var(--gold); }
.chat-send {
  width:44px; height:44px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--rose));
  border:none; cursor:pointer; font-size:1rem; transition:transform 0.2s;
}
.chat-send:hover { transform:scale(1.1); }

.insta-reveal {
  background:linear-gradient(135deg,rgba(168,85,247,0.1),rgba(255,107,157,0.1));
  border:1px solid var(--border); border-radius:12px; padding:16px;
  text-align:center; margin:16px;
}
.insta-reveal p { font-size:0.8rem; color:var(--muted); margin-bottom:10px; }
.insta-btn { background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045); border:none; border-radius:50px; padding:10px 24px; color:#fff; font-size:0.8rem; cursor:pointer; transition:transform 0.2s; }
.insta-btn:hover { transform:scale(1.05); }

/* ===================== ADMIN PANEL ===================== */
#page-admin { min-height:100vh; padding:100px 40px 40px; }
.admin-header {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:40px;
}
.admin-title { font-family:'Syne',sans-serif; font-size:2rem; }
.admin-title span { color:var(--gold); }
.admin-badge {
  background:linear-gradient(135deg,var(--gold),var(--rose));
  color:var(--deep); padding:8px 20px; border-radius:50px;
  font-size:0.8rem; font-weight:700; letter-spacing:1px;
}

.stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:32px; }
.stat-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:16px; padding:24px; position:relative; overflow:hidden;
}
.stat-card::after {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,var(--gold),var(--rose));
}
.stat-card-num { font-family:'Syne',sans-serif; font-size:2rem; color:var(--gold); font-weight:700; }
.stat-card-label { font-size:0.75rem; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-top:4px; }
.stat-card-change { font-size:0.75rem; color:var(--green); margin-top:8px; }

.admin-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.admin-panel-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:20px; overflow:hidden;
}
.panel-header {
  padding:20px 24px; border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
}
.panel-title { font-family:'Syne',sans-serif; font-size:1rem; color:var(--gold); }
.panel-action { font-size:0.75rem; color:var(--muted); cursor:pointer; }
.panel-action:hover { color:var(--gold); }

.users-list { padding:16px; }
.user-row {
  display:flex; align-items:center; gap:12px; padding:12px;
  border-radius:12px; transition:background 0.2s;
}
.user-row:hover { background:rgba(255,255,255,0.03); }
.user-row-avatar {
  width:40px; height:40px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; font-size:1.2rem;
  flex-shrink:0;
}
.uav1 { background:linear-gradient(135deg,#1a0a3d,#6b1a6b); }
.uav2 { background:linear-gradient(135deg,#0a3d1a,#1a6b3d); }
.uav3 { background:linear-gradient(135deg,#3d1a0a,#6b3d1a); }
.uav4 { background:linear-gradient(135deg,#0a1a3d,#1a3d6b); }
.uav5 { background:linear-gradient(135deg,#3d0a3d,#6b1a6b); }
.user-row-info { flex:1; }
.user-row-name { font-size:0.85rem; color:var(--cream); }
.user-row-meta { font-size:0.72rem; color:var(--muted); margin-top:2px; }
.user-row-actions { display:flex; gap:6px; }
.action-btn {
  width:30px; height:30px; border-radius:8px; border:none;
  cursor:pointer; font-size:0.75rem; transition:all 0.2s;
}
.action-verify { background:rgba(0,212,170,0.1); color:var(--teal); }
.action-verify:hover { background:rgba(0,212,170,0.2); }
.action-ban { background:rgba(255,71,87,0.1); color:var(--red); }
.action-ban:hover { background:rgba(255,71,87,0.2); }
.action-view { background:rgba(168,85,247,0.1); color:var(--gold); }
.action-view:hover { background:rgba(168,85,247,0.2); }

.status-dot { width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:6px; }
.dot-verified { background:var(--teal); }
.dot-pending { background:var(--gold); }
.dot-flagged { background:var(--red); }

/* Reports */
.report-item {
  padding:16px; border-bottom:1px solid rgba(255,255,255,0.05);
  display:flex; align-items:flex-start; gap:12px;
}
.report-item:last-child { border-bottom:none; }
.report-icon { font-size:1.5rem; flex-shrink:0; }
.report-text p { font-size:0.82rem; color:var(--cream); line-height:1.4; }
.report-text span { font-size:0.7rem; color:var(--muted); }
.report-actions { margin-left:auto; display:flex; gap:6px; flex-shrink:0; }

/* Match activity */
.activity-item {
  padding:12px 24px; display:flex; align-items:center; gap:12px;
  border-bottom:1px solid rgba(255,255,255,0.03);
}
.activity-icon { font-size:1.2rem; }
.activity-text { font-size:0.8rem; color:var(--muted); flex:1; }
.activity-text strong { color:var(--cream); }
.activity-time { font-size:0.7rem; color:rgba(155,139,180,0.5); }

/* ===================== ASTRO DETAILS ===================== */
.astro-card {
  background:var(--card); border:1px solid var(--border);
  border-radius:16px; padding:20px; margin-bottom:20px;
}
.astro-title { font-family:'Syne',sans-serif; font-size:0.9rem; color:var(--gold); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.astro-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.astro-item { background:rgba(255,255,255,0.03); border-radius:10px; padding:12px; }
.astro-item-label { font-size:0.65rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); }
.astro-item-val { font-size:0.9rem; color:var(--cream); margin-top:4px; font-weight:500; }

.compat-bar { height:6px; background:rgba(255,255,255,0.1); border-radius:3px; margin-top:8px; overflow:hidden; }
.compat-fill { height:100%; border-radius:3px; background:linear-gradient(90deg,var(--gold),var(--rose)); }

/* ===================== TOAST ===================== */
.toast-container { position:fixed; bottom:32px; right:32px; z-index:9999; display:flex; flex-direction:column; gap:12px; }
.toast {
  background:linear-gradient(135deg,rgba(26,10,61,0.95),rgba(13,8,37,0.95));
  border:1px solid var(--border); border-radius:14px;
  padding:16px 20px; min-width:280px;
  display:flex; align-items:center; gap:12px;
  box-shadow:0 20px 40px rgba(0,0,0,0.3);
  animation:toastIn 0.3s ease;
